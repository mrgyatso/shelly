#!/usr/bin/env sh
# shelly-hook (plugin copy) — Claude Code PostToolUse hook.
#
# Pops the Shelly overlay when Claude writes an HTML artifact into the watched
# dir. Reads the hook JSON payload on stdin; never blocks the originating write.
#
# Unlike the app-bundled copy, this calls the `shelly` CLI from PATH (installed
# with the Shelly app), and no-ops silently if the app isn't installed —
# so the plugin is harmless on a machine without the overlay.
#
# Watched dir: $SHELLY_ARTIFACTS_DIR (default: $HOME/.shelly/artifacts).

ARTIFACTS_DIR="${SHELLY_ARTIFACTS_DIR:-$HOME/.shelly/artifacts}"
LIVE_DIR="$HOME/.shelly/live"
INDEX_PATH="$HOME/.shelly/artifact-index.json"

payload=$(cat)

# External-terminal handling (default OFF) — do not index artifacts written by a
# terminal the Board did not spawn (no SHELLY_SESSION). See shelly-session
# for the full note; opt in via ~/.shelly/external-terminals = "on".
#
# First real statement in the file, above the subshell and the trace sourcing below:
# this hook is wired to PostToolUse for Write|Edit|shell|apply_patch, so it fires on
# essentially every tool call in every session on the machine, and for a non-Board
# session the answer is always "exit 0". Worth ~3ms a call — small, but it is the
# hottest path Shelly owns and nothing above the gate is needed to evaluate it.
if [ -z "$SHELLY_SESSION" ] && [ "$(cat "${HOME}/.shelly/external-terminals" 2>/dev/null)" != "on" ]; then
  exit 0
fi

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

# Trace harness (no-op unless SHELLY_TRACE=1 / the trace.on flag file exists).
CMP_HOOK_DIR="$SCRIPT_DIR"
. "$SCRIPT_DIR/shelly-trace.sh"

# ADOPTION — a session still on the Home shelf graduates to its own project the first
# time it writes into a git repo that isn't $HOME (i.e. it ran `git init`). This must run
# BEFORE the artifacts pre-filter below, because the triggering write is a PROJECT file
# (~/snake/snake.py), not an artifact — the pre-filter would drop it.
#
# The cost guard: only a homeless session carries a marker, and the marker dir is empty
# whenever every live session is already rooted (the overwhelmingly common case). So this
# is one readdir on the hot path and spawns node ONLY while a homeless session exists —
# never for the steady-state "all my sessions are in real repos" case.
if [ -n "$(ls -A "${HOME}/.shelly/homeless" 2>/dev/null)" ]; then
  printf '%s' "$payload" | node "$SCRIPT_DIR/shelly-adopt.cjs" 2>/dev/null
fi

# Cheap pre-filter: skip the JSON parse for the 99% of writes that aren't artifacts.
case "$payload" in
  *"$ARTIFACTS_DIR"/*) ;;
  *) exit 0 ;;
esac

# Every parse below is a node spawn. shelly-session already reported a missing node
# once, at SessionStart; bail quietly rather than printing "command not found" per write.
command -v node >/dev/null 2>&1 || exit 0

# Record the hook firing the moment a write touches the artifacts dir — BEFORE the
# CLI-presence guard, so an artifact write is logged even on a plugin-only machine
# with no overlay installed. Parse fp/sid here only when tracing is on (a node spawn
# we otherwise defer past the guard, so the no-overlay path stays cheap).
if shelly_trace_on; then
  _t_fp=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log((JSON.parse(d).tool_input||{}).file_path||"")}catch(e){}})' 2>/dev/null)
  _t_sid=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})' 2>/dev/null)
  trace hook fire "corr=$_t_fp" "file_path=$_t_fp" "sid=$_t_sid" "artifacts_dir=$ARTIFACTS_DIR" "hookpid=$$"
fi

# Seam to the app: if the overlay CLI isn't installed, do nothing.
command -v shelly >/dev/null 2>&1 || { trace hook no-shelly-cli "corr=${_t_fp:-}"; exit 0; }

# Pull the artifact path(s) + session_id + cwd out of the payload. Claude's Write/Edit
# carry the target as tool_input.file_path; Codex's apply_patch/shell tools embed it in
# patch/command text — shelly-artifact-paths.cjs owns that difference and prints one
# path per line. cwd feeds shelly-index's LATE REGISTRATION only (a session with no
# registry record); a registered session's identity comes from its frozen record.
paths=$(printf '%s' "$payload" | ARTIFACTS_DIR="$ARTIFACTS_DIR" node "$SCRIPT_DIR/shelly-artifact-paths.cjs" 2>/dev/null)
SID=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})' 2>/dev/null)
CWD=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).cwd||"")}catch(e){}})' 2>/dev/null)
# Which CLI produced this session — codex transcripts live under ~/.codex (rollout-*.jsonl),
# Claude's under ~/.claude/projects. Feeds late registration's provider field only.
PROVIDER=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{const t=JSON.parse(d).transcript_path||"";console.log(/\/\.codex\/|\/rollout-[^/]*\.jsonl$/.test(t)?"codex":"claude")}catch(e){console.log("claude")}})' 2>/dev/null)
# Which user prompt this write happened under. Stamped onto the index entry so the
# PreToolUse fork hook can tell a same-turn overwrite (still authoring — allowed) from a
# rewrite of an artifact sealed in an earlier turn (forked). Empty on Claude Code < 2.1.196
# and on Codex, which carry no prompt_id — the fork hook then falls back to mtime.
PROMPT_ID=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).prompt_id||"")}catch(e){}})' 2>/dev/null)

# Push-pop disabled: artifacts no longer spawn their own OS window. The Board is
# the single surface — it ingests artifacts as tiles inside their session via the
# live poll. We DO stamp the routing index here so the Board groups the artifact
# under the WRITING session's unit (keyed on session_id; unit_key resolved from
# that session's live file — cwd is volatile, so never derive from it).
printf '%s\n' "$paths" | while IFS= read -r fp; do
  [ -n "$fp" ] || continue
  case "$fp" in
    "$ARTIFACTS_DIR"/home.html|"$ARTIFACTS_DIR"/home.*.html)
      # Agent-authored Hub/unit-home surfaces — hosted by the Board, never indexed
      # as one-off artifacts. This arm sits ABOVE the *.html arm (case matches top-down).
      trace hook skip-index "corr=$fp" "reason=unit-home"
      ;;
    "$ARTIFACTS_DIR"/_*.html)
      trace hook skip-index "corr=$fp" "reason=diagnostic-scaffold"
      ;;
    "$ARTIFACTS_DIR"/*.html)
      trace hook index-spawn "corr=$fp"
      SID="$SID" CWD="$CWD" PROVIDER="$PROVIDER" PROMPT_ID="$PROMPT_ID" node "$SCRIPT_DIR/shelly-index.cjs" "$fp" "$LIVE_DIR" "$INDEX_PATH" 2>/dev/null
      trace hook index-done "corr=$fp"
      ;;
  esac
done

exit 0
