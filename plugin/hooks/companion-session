#!/usr/bin/env sh
# companion-session — Claude Code SessionStart hook.
#
# Hands this session its per-INSTANCE Companion live path and seeds the roster:
#   1. derive live/<slug>--<shortid>.json (shared with the artifact observer),
#   2. write an initial stub there if absent, so the instance shows on the Board
#      roster before its first Stop (skip-if-exists keeps resume/compact idempotent),
#   3. inject the path into the session context so the agent writes the right file
#      from turn 1 (no self-computed slug — the old scheme collided per repo),
#   4. prune live/*.json older than 7 days so crashed sessions don't pile up.
#
# Liveness is mtime-based (the overlay archives a file untouched for ~30 min), so
# the 7-day prune is far below any live-but-idle instance and only sweeps the dead.

PRUNE_DAYS=7

payload=$(cat)

# Node is a hard requirement — the hooks below are Node programs. Claude Code ships
# as a native binary, so `claude` on PATH does not imply node. Say so once, here at
# SessionStart, and let the per-tool hooks no-op quietly rather than printing
# "node: command not found" on every Write.
if ! command -v node >/dev/null 2>&1; then
  echo "Companion is inactive: node is not on PATH. Its hooks need Node 18+ — install it (brew install node), then run 'companion setup'." >&2
  exit 0
fi

cwd=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).cwd||process.cwd())}catch(e){console.log(process.cwd())}})')
session_id=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})')
# Which CLI is running this session. Codex CLI runs these same hooks (its hooks
# system is Claude-Code-shaped and its plugin loader consumes this plugin as-is);
# its transcripts are rollout-*.jsonl files under ~/.codex, Claude's live under
# ~/.claude/projects. Recorded in the identity registry so the app knows which
# CLI to `--resume` a session with. Defaults to claude when there is no signal.
provider=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{const t=JSON.parse(d).transcript_path||"";console.log(/\/\.codex\/|\/rollout-[^/]*\.jsonl$/.test(t)?"codex":"claude")}catch(e){console.log("claude")}})')

# Ignore tool-internal observer sessions. claude-mem (and similar) spawn long-lived
# `claude` processes under ~/.claude-mem/observer-sessions to watch other sessions;
# they inherit this SessionStart hook but are NOT user work. Bail before writing any
# live file / sidecar so they never appear on the Board roster (the app filters them
# too, but stopping at the source keeps the live/ dir clean).
case "$cwd" in
  */.claude-mem/*|*/.claude-mem) exit 0 ;;
esac

# External-terminal handling (default OFF). A terminal the Board did not spawn
# carries no COMPANION_SESSION; by default the Companion ignores such external
# terminals entirely — no roster entry, no sidecars, no artifact observer — so a
# plain terminal that merely has the plugin installed stays silent (no takeover,
# no artifacts generated for sessions not using the app). Opt back in per-machine
# by writing "on" to ~/.claude/companion/external-terminals. This gates only
# hook-driven terminals; external *agents* (the remote/ push path) are unaffected.
#
# Being ignored is fine; being ignored *silently* is not — a user who installed both
# pieces and typed `claude` in their own terminal has no way to tell the difference
# between "off by design" and "broken". Say it once per machine (SessionStart stdout
# is injected as agent context) so the agent can point them at the app, then stay quiet.
if [ -z "$COMPANION_SESSION" ] && [ "$(cat "${HOME}/.claude/companion/external-terminals" 2>/dev/null)" != "on" ]; then
  hint="${HOME}/.claude/companion/.external-hint-shown"
  if [ ! -f "$hint" ]; then
    mkdir -p "${HOME}/.claude/companion" 2>/dev/null
    : > "$hint" 2>/dev/null
    echo "Companion is installed but inactive in this terminal — it only tracks sessions the app itself starts. If the user expects Companion here, tell them to run 'companion board' and start the session from the app, or 'companion setup --external-terminals' to track every terminal."
  fi
  exit 0
fi

# Trace harness (no-op unless enabled). companion-livepath.sh sources it too.
CMP_HOOK_DIR=$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)
. "$CMP_HOOK_DIR/companion-trace.sh"

line=$(sh "$(dirname "$0")/companion-livepath.sh" "$cwd" "$session_id")
live_path=$(printf '%s' "$line" | cut -f1)
project=$(printf '%s' "$line" | cut -f2)
shortid=$(printf '%s' "$line" | cut -f3)
is_repo=$(printf '%s' "$line" | cut -f4)
unit_key=$(printf '%s' "$line" | cut -f5)
root=$(printf '%s' "$line" | cut -f6)
digest_path="${HOME}/.claude/companion/artifacts/home.${unit_key}.html"
# The stem slug (live/<slug>--<shortid>.json) — the session's on-disk name. Recorded
# alongside unit_key because the two DIFFER for $HOME sessions ('gyatso' vs '__home__');
# artifact source stamps are built from the slug and must match the live stem.
stem=$(basename "$live_path" .json)
slug=${stem%--"$shortid"}

# 1a. REGISTER FIRST — write the authoritative identity record BEFORE the
#     best-effort sidecars below. register() is the source of truth of the
#     identity redesign, so it must be the most-protected step, not the last.
#     The record is keyed by the FULL session_id and IMMUTABLE (resume/compact
#     find it and leave it untouched), so one early write per session is enough.
#     Running it ahead of the sidecar node-spawns means a short-lived session
#     (which can be torn down mid-hook) still gets registered. Sits below the
#     .claude-mem bail so the observer's own worker never self-registers.
if [ -n "$session_id" ]; then
  node "$CMP_HOOK_DIR/companion-identity.cjs" register \
    "$session_id" "$unit_key" "$is_repo" "$root" "$project" "${COMPANION_SESSION:-}" "$provider" "$slug" 2>/dev/null
  trace session register "sid=$shortid" "unit_key=$unit_key" "slug=$slug" "root=$root" "provider=$provider"
fi
trace session start "sid=$shortid" "cwd=$cwd" "live=$live_path" "project=$project" "is_repo=$is_repo" "unit_key=$unit_key" "owned=${COMPANION_SESSION:-}"

live_dir=$(dirname "$live_path")
mkdir -p "$live_dir" 2>/dev/null

# 1a-bis. THE HOMELESS LATCH. A session rooted in $HOME has no project of its own yet: it
#     sits on the shared Home shelf and is allowed to GRADUATE, exactly once, the first
#     time it writes into a real git repo (companion-adopt.cjs, from the Write/Edit hook).
#     The marker IS that permission — no marker means "already rooted", and rooted is
#     terminal, so a session can never adopt twice or wander between projects.
#     Its other job is a cost guard: companion-hook skips the adoption path entirely when
#     this dir is empty, so a machine whose sessions are all in real repos pays nothing.
#     Cleared on resume of an already-adopted session (root moved off $HOME).
homeless_dir="${HOME}/.claude/companion/homeless"
if [ "$unit_key" = "__home__" ]; then
  mkdir -p "$homeless_dir" 2>/dev/null
  : > "${homeless_dir}/${shortid}" 2>/dev/null
  trace session homeless "sid=$shortid" "root=$root"
else
  rm -f "${homeless_dir}/${shortid}" 2>/dev/null
fi

# 1. Seed an initial stub if this instance has no file yet (resume/compact reuse
#    the same session_id, so they find the existing file and leave it untouched).
#    is_repo + unit_key let the Board group sessions into a per-UNIT home; the
#    agent is asked (below) to preserve them when it rewrites this file.
if [ ! -f "$live_path" ]; then
  LIVE_PATH="$live_path" PROJECT="$project" IS_REPO="$is_repo" UNIT_KEY="$unit_key" PROVIDER="$provider" node -e '
    const fs=require("fs");
    const stub={working:"Session started",where:[],next:[],project:process.env.PROJECT,
      is_repo:process.env.IS_REPO==="1",unit_key:process.env.UNIT_KEY,
      provider:process.env.PROVIDER||"claude"};
    try { fs.writeFileSync(process.env.LIVE_PATH, JSON.stringify(stub)); } catch (e) {}
  ' 2>/dev/null
fi

stem=$(basename "$live_path" .json)

# 1b. If this session was spawned BY the Board (it injects COMPANION_SESSION=<tabId>
#     into the claude it owns; the hook inherits it), bind this session's live-file
#     stem (<slug>--<shortid>) -> tabId in owned-sessions.json. The Board reads this
#     sidecar (via live.rs) to match the terminal it spawned to the live source this
#     session produces — agent-proof + Board-owned, mirroring companion-index.cjs.
#     Written every start (outside the first-run guard) so resume/compact re-bind.
if [ -n "$COMPANION_SESSION" ]; then
  STEM="$stem" TAB="$COMPANION_SESSION" OWNED="${HOME}/.claude/companion/owned-sessions.json" node -e '
    const fs=require("fs");
    const p=process.env.OWNED;
    let m={};
    try { m=JSON.parse(fs.readFileSync(p,"utf8"))||{}; } catch (e) {}
    const stem=process.env.STEM, tab=process.env.TAB;
    // Eviction-at-registration: one terminal box (tabId) hosts one live session.
    // Drop any OTHER stem still mapped to this tab (a prior claude in the same PTY
    // whose entry was never pruned), so the Board never sees two slugs claim one
    // tab — the source-side complement to board.ts'"'"'s freshest-source tie-break.
    for (const k of Object.keys(m)) { if (k!==stem && m[k]===tab) delete m[k]; }
    m[stem]=tab;
    try { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p); } catch (e) {}
  ' 2>/dev/null
  trace session bind-owned "stem=$stem" "tab=$COMPANION_SESSION"
fi

# 1c. Record this session's project ROOT (gitroot, else cwd) keyed by its live-file
#     stem in session-dirs.json — a Board-owned, agent-proof sidecar the Board reads
#     (via live.rs) to resolve a unit's absolute directory, so "+ session in this
#     project" knows where to spawn. Written for EVERY session (external too).
#     (root is derived once in companion-livepath.sh and parsed above — no second git call.)
STEM="$stem" ROOT="$root" DIRS="${HOME}/.claude/companion/session-dirs.json" node -e '
  const fs=require("fs");
  const p=process.env.DIRS;
  let m={};
  try { m=JSON.parse(fs.readFileSync(p,"utf8"))||{}; } catch (e) {}
  m[process.env.STEM]=process.env.ROOT;
  try { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p); } catch (e) {}
' 2>/dev/null
trace session record-dir "stem=$stem" "root=$root"

# 1d. Record this session's FULL session_id keyed by stem in session-ids.json
#     (the stem only carries the 8-char shortid, which can't drive `claude
#     --resume`). The Board injects it per source so a session closed off the
#     roster can be REJOINED via `claude --resume <id>`. Agent-proof sidecar.
#     GUARDED on COMPANION_SESSION (same as 1b): only sessions the Board OWNS get
#     a resume id, so "has session_id" cleanly means "was Board-launched" — an
#     external session's restore just un-hides, never spawns a duplicate claude.
if [ -n "$COMPANION_SESSION" ] && [ -n "$session_id" ]; then
  STEM="$stem" SID="$session_id" IDS="${HOME}/.claude/companion/session-ids.json" node -e '
    const fs=require("fs");
    const p=process.env.IDS;
    let m={};
    try { m=JSON.parse(fs.readFileSync(p,"utf8"))||{}; } catch (e) {}
    m[process.env.STEM]=process.env.SID;
    try { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p); } catch (e) {}
  ' 2>/dev/null
  trace session record-id "stem=$stem"
fi

# (REGISTER now runs FIRST — see section 1a above. It was moved out of this
#  last-step slot so a short-lived session can't be torn down before it registers.)

# 2. Prune dead live files (mtime older than PRUNE_DAYS) so the roster's archive
#    list doesn't grow unbounded across crashed/abandoned sessions.
find "$live_dir" -maxdepth 1 -name '*.json' -type f -mtime "+${PRUNE_DAYS}" -exec rm -f {} + 2>/dev/null

# 2 (cont). GC orphaned bookkeeping. The prune above removes dead live FILES, but the
#     per-session sidecars (owned-sessions / session-dirs / session-ids / dismissed) and
#     the immutable identity records under sessions/ were only trimmed on a GRACEFUL
#     SessionEnd — a crash / kill / overlay-restart-SIGHUP (reason "other") leaves them, so
#     they grew unbounded. Drop any sidecar entry whose live file is gone, and any sessions/
#     record that is BOTH old (>REGISTRY_PRUNE_DAYS) and unreferenced by a surviving live
#     file. Best-effort; the current session's live file + sidecars were written above, so
#     it is never self-evicted. Atomic tmp+rename writes; never blocks the hook.
REGISTRY_PRUNE_DAYS=30 LIVE_DIR="$live_dir" CMP_DIR="${HOME}/.claude/companion" node -e '
  const fs=require("fs"), path=require("path");
  const cmp=process.env.CMP_DIR, liveDir=process.env.LIVE_DIR;
  const regDays=parseInt(process.env.REGISTRY_PRUNE_DAYS,10)||30;
  let liveStems=[];
  try { liveStems=fs.readdirSync(liveDir).filter(f=>f.endsWith(".json")).map(f=>f.slice(0,-5)); } catch(e){}
  const stemSet=new Set(liveStems);
  // shortid suffix (after the last "--") of each surviving live stem
  const liveShort=new Set(liveStems.map(s=>{const i=s.lastIndexOf("--");return i>=0?s.slice(i+2):"";}).filter(Boolean));
  // object sidecars keyed by stem: drop entries with no surviving live file
  for (const f of ["owned-sessions.json","session-dirs.json","session-ids.json"]) {
    const p=path.join(cmp,f);
    try {
      const m=JSON.parse(fs.readFileSync(p,"utf8")); let changed=false;
      for (const k of Object.keys(m)) if (!stemSet.has(k)) { delete m[k]; changed=true; }
      if (changed) { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t,p); }
    } catch(e){}
  }
  // homeless/<shortid> latches: drop any whose live session is gone, so a crashed
  // home session cannot leave a marker behind that keeps the adoption path (and its
  // node spawn) armed on every Write forever.
  try {
    const hd=path.join(cmp,"homeless");
    for (const f of fs.readdirSync(hd)) if (!liveShort.has(f)) { try { fs.rmSync(path.join(hd,f)); } catch(e){} }
  } catch(e){}
  // dismissed.json is an ARRAY of stems
  try {
    const p=path.join(cmp,"dismissed.json");
    const a=JSON.parse(fs.readFileSync(p,"utf8"));
    if (Array.isArray(a)) { const b=a.filter(x=>stemSet.has(x));
      if (b.length!==a.length) { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(b)); fs.renameSync(t,p); } }
  } catch(e){}
  // sessions/<id>.json identity records: prune only when old AND unreferenced by a live file
  try {
    const sd=path.join(cmp,"sessions"), now=Date.now();
    for (const f of fs.readdirSync(sd)) {
      if (!f.endsWith(".json")) continue;
      const fp=path.join(sd,f);
      let sid=""; try { sid=(JSON.parse(fs.readFileSync(fp,"utf8"))||{}).session_id||""; } catch(e){}
      const short=sid.slice(0,8).replace(/[^A-Za-z0-9]/g,"-");
      if (short && liveShort.has(short)) continue;          // a live session owns it → keep
      let ageDays=Infinity; try { ageDays=(now-fs.statSync(fp).mtimeMs)/86400000; } catch(e){}
      if (ageDays>regDays) { try { fs.rmSync(fp); } catch(e){} }
    }
  } catch(e){}
' 2>/dev/null

# 2b. Worktree-awareness. If ANOTHER session is already active in this same repo
#     root (its live file was touched within ~30 min), hint this agent to isolate
#     its edits in a git worktree so two agents in one repo don't clobber each
#     other's files. Repo-only; a one-off dir never triggers it.
wt_note=""
if [ "$is_repo" = "1" ]; then
  other_active=$(STEM="$stem" ROOT="$root" DIRS="${HOME}/.claude/companion/session-dirs.json" LIVE_DIR="$live_dir" node -e '
    const fs=require("fs"),path=require("path");
    try{
      const dirs=JSON.parse(fs.readFileSync(process.env.DIRS,"utf8"))||{};
      const me=process.env.STEM,root=process.env.ROOT,ld=process.env.LIVE_DIR,now=Date.now();
      for(const [stem,r] of Object.entries(dirs)){
        if(stem===me||r!==root) continue;
        try{ if(now-fs.statSync(path.join(ld,stem+".json")).mtimeMs < 1800000){console.log("1");break;} }catch(e){}
      }
    }catch(e){}
  ' 2>/dev/null)
  if [ "$other_active" = "1" ]; then
    wt_note="HEADS-UP: another agent is already active in this repo (${project}). To avoid clobbering each other's files, create and work inside a git worktree (git worktree add ../${project}-<task> -b <task>) instead of editing the shared working tree directly."
  fi
fi

# 3. Tell the agent its live path (a status/roster heartbeat) AND that it now authors
#    artifact HTML itself, inline, when a turn earns one. The live file is no longer
#    rendered into a card; a Stop-hook backstop (companion-artifact-gate) reminds the agent
#    once if a substantive turn ends with nothing written.
artifacts_dir="${COMPANION_ARTIFACTS_DIR:-$HOME/.claude/companion/artifacts}"
LIVE_PATH="$live_path" ARTIFACTS_DIR="$artifacts_dir" WT_NOTE="$wt_note" node -e '
  const p=process.env.LIVE_PATH;
  const a=process.env.ARTIFACTS_DIR;
  const wt=process.env.WT_NOTE ? "\n"+process.env.WT_NOTE : "";
  const ctx=`Companion live surface: rewrite your live state to ${p} on each work turn. This is a `+
    `STATUS heartbeat only — it drives the Board roster AND the always-on status strip; it is NOT `+
    `rendered into an artifact. Shape: {"working":"…","where":["…"],"next":[{"title":"…","sub":"…",`+
    `"kind":"decision|todo|blocked"}],"project":"…","is_repo":<bool>,"unit_key":"…"}. Use exactly `+
    `this path — keyed to this session instance — and PRESERVE is_repo + unit_key + provider `+
    `verbatim (the Board groups sessions into a per-unit home by them). working = what you are doing now; `+
    `where[] = cumulative state THIS SESSION (not only this turn); next[] = the propulsive next `+
    `moves. Every work turn, drive toward shipping: end on the next move — recommend the strongest `+
    `option and why, ask sharp questions the user can decide in one read, and make next[] concrete `+
    `actions and real decisions (not a recap). State decisions, status, and blockers plainly.\n\n`+
    `Artifacts: EVERY TURN ENDS WITH ONE — no exemptions. You are not deciding whether, only what `+
    `shape. AUTHOR THE HTML YOURSELF: write a self-contained .html into ${a}. There is no renderer `+
    `and no background observer; you write the file, in full context, the first time (highest-quality, `+
    `and cheapest on a warm cache). ONE TURN, ONE SLUG: never rewrite a slug you shipped in an EARLIER `+
    `turn — the user may still be reading it, and the 💬 comments they typed live only in that iframe, `+
    `so a rewrite destroys both. Write a fresh slug; it lands as its own card and the old one stays one `+
    `flip back. Within THIS turn, overwrite your own artifact freely. Exception: home.<unit>.html, the `+
    `per-project digest, is a living document and updates in place. SIZE IT TO THE TURN: a decision, plan, review or analysis earns a `+
    `full document; a quick answer or a lookup earns a COMPACT CARD — small is the correct finished `+
    `form for a light turn, so do not pad it. An artifact is a STEERING surface, not a transcript: lead `+
    `with the pending decision or blocker and make it the loudest thing; show only what is needed to `+
    `act on it; push evidence down and keep it collapsible; CUT the recap of what already happened. `+
    `EVERY artifact must END WITH AN ANSWERABLE SURFACE — a short "Next steps" ballot of concrete moves `+
    `the user acts on from the Board (✓ do it / ✎ note / ✗ skip), plus every question you raise wired as `+
    `its OWN clickable item. A question left as prose the user cannot click is a bug; the lone chat bar `+
    `is a fallback, not the answer. This holds even when the work is DONE: say so, then hand over the `+
    `next move ("nothing left here; here is what I would pick up next, or tell me where to go"). `+
    `"Nothing to decide" is never true — choosing the next piece of work IS the decision. It holds for a bespoke `+
    `look-at design too: the visual is yours to craft, but the user must still be able to respond in `+
    `place. EVERY artifact must include the size-reporter script and the companion-meta block or it `+
    `renders at the wrong size. Load the companion:prefer-html skill for the full template WHEN building `+
    `a non-trivial artifact (anything beyond a compact pill) — it is the pattern library, carrying the `+
    `interaction helper (commentable blocks + the Decide review form), those required snippets, and the `+
    `Broadsheet house style. Pattern menu — pick by content shape: compact pill (quick answer / status `+
    `flip) · blob canvas (N independent points as floating expandable colored cards; DEFAULT for `+
    `multi-point turns; the one pattern where multiple palette colors are sanctioned) · paginated wizard `+
    `(one deep sequence as pages 1..N ending on a decisions page) · sidebar multi-page (3+ peer subjects, `+
    `jump-anywhere) · two-zone (prose + one explanatory visual) · single scroll (one narrative) · bespoke `+
    `dashboard (presentation-first). Load companion:prefer-html for the template once you\u0027ve picked. `+
    `Shell: set html/body background to oklch(0.945 0.014 60) (the app shade) by default. Optionally — `+
    `occasionally, when the turn earns it — an artifact may repaint the WHOLE surface: declare `+
    `"shell": {"bg": "…", "ink": "…"} in companion-meta, post {source:\u0027companion-artifact\u0027, `+
    `kind:\u0027shell\u0027, bg, ink} to parent on load, and use that same bg as the page background. `+
    `Curated set only (bg/ink): paper #FBFAF6/#171A1F · slate #E7ECF1/#1B2530 · mint #E6F1EA/#16281F · `+
    `clay #F3E7DF/#2A1C14 · ink #14181D/#E8EDF3. Never any other color; never a partial repaint (the `+
    `seam is the enemy). A Stop-hook backstop hands the turn back once if it ends with nothing written, `+
    `but author it inline.`+wt;
  process.stdout.write(JSON.stringify({hookSpecificOutput:{hookEventName:"SessionStart",additionalContext:ctx}}));
'
exit 0
