#!/usr/bin/env sh
# companion-session — Claude Code SessionStart hook.
#
# Hands this session its per-INSTANCE Companion live path and seeds the roster:
#   1. derive live/<slug>--<shortid>.json (shared with the artifact observer),
#   2. write an initial stub there if absent, so the instance shows on the Board
#      roster before its first Stop (skip-if-exists keeps resume/compact idempotent),
#   3. inject the path into the session context so the agent writes the right file
#      from turn 1 (no self-computed slug — the old scheme collided per repo),
#   4. prune live/*.json older than 7 days so crashed sessions don't pile up.
#
# Liveness is mtime-based (the overlay archives a file untouched for ~30 min), so
# the 7-day prune is far below any live-but-idle instance and only sweeps the dead.

PRUNE_DAYS=7

payload=$(cat)

cwd=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).cwd||process.cwd())}catch(e){console.log(process.cwd())}})')
session_id=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})')

# Ignore tool-internal observer sessions. claude-mem (and similar) spawn long-lived
# `claude` processes under ~/.claude-mem/observer-sessions to watch other sessions;
# they inherit this SessionStart hook but are NOT user work. Bail before writing any
# live file / sidecar so they never appear on the Board roster (the app filters them
# too, but stopping at the source keeps the live/ dir clean).
case "$cwd" in
  */.claude-mem/*|*/.claude-mem) exit 0 ;;
esac

# External-terminal handling (default OFF). A terminal the Board did not spawn
# carries no COMPANION_SESSION; by default the Companion ignores such external
# terminals entirely — no roster entry, no sidecars, no artifact observer — so a
# plain terminal that merely has the plugin installed stays silent (no takeover,
# no artifacts generated for sessions not using the app). Opt back in per-machine
# by writing "on" to ~/.claude/companion/external-terminals. This gates only
# hook-driven terminals; external *agents* (the remote/ push path) are unaffected.
if [ -z "$COMPANION_SESSION" ] && [ "$(cat "${HOME}/.claude/companion/external-terminals" 2>/dev/null)" != "on" ]; then
  exit 0
fi

# Trace harness (no-op unless enabled). companion-livepath.sh sources it too.
CMP_HOOK_DIR=$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)
. "$CMP_HOOK_DIR/companion-trace.sh"

line=$(sh "$(dirname "$0")/companion-livepath.sh" "$cwd" "$session_id")
live_path=$(printf '%s' "$line" | cut -f1)
project=$(printf '%s' "$line" | cut -f2)
shortid=$(printf '%s' "$line" | cut -f3)
is_repo=$(printf '%s' "$line" | cut -f4)
unit_key=$(printf '%s' "$line" | cut -f5)
root=$(printf '%s' "$line" | cut -f6)
digest_path="${HOME}/.claude/companion/artifacts/home.${unit_key}.html"

# 1a. REGISTER FIRST — write the authoritative identity record BEFORE the
#     best-effort sidecars below. register() is the source of truth of the
#     identity redesign, so it must be the most-protected step, not the last.
#     The record is keyed by the FULL session_id and IMMUTABLE (resume/compact
#     find it and leave it untouched), so one early write per session is enough.
#     Running it ahead of the sidecar node-spawns means a short-lived session
#     (which can be torn down mid-hook) still gets registered. Sits below the
#     .claude-mem bail so the observer's own worker never self-registers.
if [ -n "$session_id" ]; then
  node "$CMP_HOOK_DIR/companion-identity.cjs" register \
    "$session_id" "$unit_key" "$is_repo" "$root" "$project" "${COMPANION_SESSION:-}" 2>/dev/null
  trace session register "sid=$shortid" "unit_key=$unit_key" "root=$root"
fi
trace session start "sid=$shortid" "cwd=$cwd" "live=$live_path" "project=$project" "is_repo=$is_repo" "unit_key=$unit_key" "owned=${COMPANION_SESSION:-}"

live_dir=$(dirname "$live_path")
mkdir -p "$live_dir" 2>/dev/null

# 1. Seed an initial stub if this instance has no file yet (resume/compact reuse
#    the same session_id, so they find the existing file and leave it untouched).
#    is_repo + unit_key let the Board group sessions into a per-UNIT home; the
#    agent is asked (below) to preserve them when it rewrites this file.
if [ ! -f "$live_path" ]; then
  LIVE_PATH="$live_path" PROJECT="$project" IS_REPO="$is_repo" UNIT_KEY="$unit_key" node -e '
    const fs=require("fs");
    const stub={working:"Session started",where:[],next:[],project:process.env.PROJECT,
      is_repo:process.env.IS_REPO==="1",unit_key:process.env.UNIT_KEY};
    try { fs.writeFileSync(process.env.LIVE_PATH, JSON.stringify(stub)); } catch (e) {}
  ' 2>/dev/null
fi

stem=$(basename "$live_path" .json)

# 1b. If this session was spawned BY the Board (it injects COMPANION_SESSION=<tabId>
#     into the claude it owns; the hook inherits it), bind this session's live-file
#     stem (<slug>--<shortid>) -> tabId in owned-sessions.json. The Board reads this
#     sidecar (via live.rs) to match the terminal it spawned to the live source this
#     session produces — agent-proof + Board-owned, mirroring companion-index.cjs.
#     Written every start (outside the first-run guard) so resume/compact re-bind.
if [ -n "$COMPANION_SESSION" ]; then
  STEM="$stem" TAB="$COMPANION_SESSION" OWNED="${HOME}/.claude/companion/owned-sessions.json" node -e '
    const fs=require("fs");
    const p=process.env.OWNED;
    let m={};
    try { m=JSON.parse(fs.readFileSync(p,"utf8"))||{}; } catch (e) {}
    const stem=process.env.STEM, tab=process.env.TAB;
    // Eviction-at-registration: one terminal box (tabId) hosts one live session.
    // Drop any OTHER stem still mapped to this tab (a prior claude in the same PTY
    // whose entry was never pruned), so the Board never sees two slugs claim one
    // tab — the source-side complement to board.ts'"'"'s freshest-source tie-break.
    for (const k of Object.keys(m)) { if (k!==stem && m[k]===tab) delete m[k]; }
    m[stem]=tab;
    try { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p); } catch (e) {}
  ' 2>/dev/null
  trace session bind-owned "stem=$stem" "tab=$COMPANION_SESSION"
fi

# 1c. Record this session's project ROOT (gitroot, else cwd) keyed by its live-file
#     stem in session-dirs.json — a Board-owned, agent-proof sidecar the Board reads
#     (via live.rs) to resolve a unit's absolute directory, so "+ session in this
#     project" knows where to spawn. Written for EVERY session (external too).
#     (root is derived once in companion-livepath.sh and parsed above — no second git call.)
STEM="$stem" ROOT="$root" DIRS="${HOME}/.claude/companion/session-dirs.json" node -e '
  const fs=require("fs");
  const p=process.env.DIRS;
  let m={};
  try { m=JSON.parse(fs.readFileSync(p,"utf8"))||{}; } catch (e) {}
  m[process.env.STEM]=process.env.ROOT;
  try { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p); } catch (e) {}
' 2>/dev/null
trace session record-dir "stem=$stem" "root=$root"

# 1d. Record this session's FULL session_id keyed by stem in session-ids.json
#     (the stem only carries the 8-char shortid, which can't drive `claude
#     --resume`). The Board injects it per source so a session closed off the
#     roster can be REJOINED via `claude --resume <id>`. Agent-proof sidecar.
#     GUARDED on COMPANION_SESSION (same as 1b): only sessions the Board OWNS get
#     a resume id, so "has session_id" cleanly means "was Board-launched" — an
#     external session's restore just un-hides, never spawns a duplicate claude.
if [ -n "$COMPANION_SESSION" ] && [ -n "$session_id" ]; then
  STEM="$stem" SID="$session_id" IDS="${HOME}/.claude/companion/session-ids.json" node -e '
    const fs=require("fs");
    const p=process.env.IDS;
    let m={};
    try { m=JSON.parse(fs.readFileSync(p,"utf8"))||{}; } catch (e) {}
    m[process.env.STEM]=process.env.SID;
    try { const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p); } catch (e) {}
  ' 2>/dev/null
  trace session record-id "stem=$stem"
fi

# (REGISTER now runs FIRST — see section 1a above. It was moved out of this
#  last-step slot so a short-lived session can't be torn down before it registers.)

# 2. Prune dead live files (mtime older than PRUNE_DAYS) so the roster's archive
#    list doesn't grow unbounded across crashed/abandoned sessions.
find "$live_dir" -maxdepth 1 -name '*.json' -type f -mtime "+${PRUNE_DAYS}" -exec rm -f {} + 2>/dev/null

# 2b. Worktree-awareness. If ANOTHER session is already active in this same repo
#     root (its live file was touched within ~30 min), hint this agent to isolate
#     its edits in a git worktree so two agents in one repo don't clobber each
#     other's files. Repo-only; a one-off dir never triggers it.
wt_note=""
if [ "$is_repo" = "1" ]; then
  other_active=$(STEM="$stem" ROOT="$root" DIRS="${HOME}/.claude/companion/session-dirs.json" LIVE_DIR="$live_dir" node -e '
    const fs=require("fs"),path=require("path");
    try{
      const dirs=JSON.parse(fs.readFileSync(process.env.DIRS,"utf8"))||{};
      const me=process.env.STEM,root=process.env.ROOT,ld=process.env.LIVE_DIR,now=Date.now();
      for(const [stem,r] of Object.entries(dirs)){
        if(stem===me||r!==root) continue;
        try{ if(now-fs.statSync(path.join(ld,stem+".json")).mtimeMs < 1800000){console.log("1");break;} }catch(e){}
      }
    }catch(e){}
  ' 2>/dev/null)
  if [ "$other_active" = "1" ]; then
    wt_note="HEADS-UP: another agent is already active in this repo (${project}). To avoid clobbering each other's files, create and work inside a git worktree (git worktree add ../${project}-<task> -b <task>) instead of editing the shared working tree directly."
  fi
fi

# 3. Tell the agent its live path (a status/roster heartbeat) AND that it now authors
#    artifact HTML itself, inline, when a turn earns one. The live file is no longer
#    rendered into a card; a Stop-hook backstop (companion-artifact-gate) reminds the agent
#    once if a substantive turn ends with nothing written.
artifacts_dir="${COMPANION_ARTIFACTS_DIR:-$HOME/.claude/companion/artifacts}"
LIVE_PATH="$live_path" ARTIFACTS_DIR="$artifacts_dir" WT_NOTE="$wt_note" node -e '
  const p=process.env.LIVE_PATH;
  const a=process.env.ARTIFACTS_DIR;
  const wt=process.env.WT_NOTE ? "\n"+process.env.WT_NOTE : "";
  const ctx=`Companion live surface: rewrite your live state to ${p} on each work turn. This is a `+
    `STATUS heartbeat only — it drives the Board roster AND the always-on status strip; it is NOT `+
    `rendered into an artifact. Shape: {"working":"…","where":["…"],"next":[{"title":"…","sub":"…",`+
    `"kind":"decision|todo|blocked"}],"project":"…","is_repo":<bool>,"unit_key":"…"}. Use exactly `+
    `this path — keyed to this session instance — and PRESERVE is_repo + unit_key verbatim (the `+
    `Board groups sessions into a per-unit home by them). working = what you are doing now; `+
    `where[] = cumulative state THIS SESSION (not only this turn); next[] = the propulsive next `+
    `moves. Every work turn, drive toward shipping: end on the next move — recommend the strongest `+
    `option and why, ask sharp questions the user can decide in one read, and make next[] concrete `+
    `actions and real decisions (not a recap). State decisions, status, and blockers plainly.\n\n`+
    `Artifacts: when a turn is substantive enough to earn a visual — a decision, comparison, plan, `+
    `analysis, or a status the user will want to see and react to — AUTHOR THE HTML YOURSELF: write `+
    `a self-contained .html into ${a}. There is no renderer and no background observer; you write `+
    `the file, in full context, the first time (highest-quality, and cheapest on a warm cache). An `+
    `artifact is a STEERING surface, not a transcript: lead with the pending decision or blocker and `+
    `make it the loudest thing; show only what is needed to act on it; push evidence down and keep it `+
    `collapsible; CUT the recap of what already happened; end by proposing the next move. Skip trivial `+
    `turns (quick answers, lookups, conversational replies) — no artifact. EVERY artifact must include `+
    `the size-reporter script and the companion-meta block (code in the skill) or it renders at the `+
    `wrong size. Load the prefer-html skill for the how — the interaction helper (commentable blocks + `+
    `the Decide review form), those required snippets, and the Broadsheet house style. A Stop-hook `+
    `backstop reminds you once if a substantive turn ends with nothing written, but author it inline.`+wt;
  process.stdout.write(JSON.stringify({hookSpecificOutput:{hookEventName:"SessionStart",additionalContext:ctx}}));
'
exit 0
