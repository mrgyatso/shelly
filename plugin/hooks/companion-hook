#!/usr/bin/env sh
# companion-hook (plugin copy) — Claude Code PostToolUse hook.
#
# Pops the Companion overlay when Claude writes an HTML artifact into the watched
# dir. Reads the hook JSON payload on stdin; never blocks the originating write.
#
# Unlike the app-bundled copy, this calls the `companion` CLI from PATH (installed
# with the Companion Overlay app), and no-ops silently if the app isn't installed —
# so the plugin is harmless on a machine without the overlay.
#
# Watched dir: $COMPANION_ARTIFACTS_DIR (default: $HOME/.claude/companion/artifacts).

ARTIFACTS_DIR="${COMPANION_ARTIFACTS_DIR:-$HOME/.claude/companion/artifacts}"
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
LIVE_DIR="$HOME/.claude/companion/live"
INDEX_PATH="$HOME/.claude/companion/artifact-index.json"

# Trace harness (no-op unless COMPANION_TRACE=1 / the trace.on flag file exists).
CMP_HOOK_DIR="$SCRIPT_DIR"
. "$SCRIPT_DIR/companion-trace.sh"

payload=$(cat)

# External-terminal handling (default OFF) — do not index artifacts written by a
# terminal the Board did not spawn (no COMPANION_SESSION). See companion-session
# for the full note; opt in via ~/.claude/companion/external-terminals = "on".
if [ -z "$COMPANION_SESSION" ] && [ "$(cat "${HOME}/.claude/companion/external-terminals" 2>/dev/null)" != "on" ]; then
  exit 0
fi

# Cheap pre-filter: skip the JSON parse for the 99% of writes that aren't artifacts.
case "$payload" in
  *"$ARTIFACTS_DIR"/*) ;;
  *) exit 0 ;;
esac

# Every parse below is a node spawn. companion-session already reported a missing node
# once, at SessionStart; bail quietly rather than printing "command not found" per write.
command -v node >/dev/null 2>&1 || exit 0

# Record the hook firing the moment a write touches the artifacts dir — BEFORE the
# CLI-presence guard, so an artifact write is logged even on a plugin-only machine
# with no overlay installed. Parse fp/sid here only when tracing is on (a node spawn
# we otherwise defer past the guard, so the no-overlay path stays cheap).
if companion_trace_on; then
  _t_fp=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log((JSON.parse(d).tool_input||{}).file_path||"")}catch(e){}})' 2>/dev/null)
  _t_sid=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})' 2>/dev/null)
  trace hook fire "corr=$_t_fp" "file_path=$_t_fp" "sid=$_t_sid" "artifacts_dir=$ARTIFACTS_DIR" "hookpid=$$"
fi

# Seam to the app: if the overlay CLI isn't installed, do nothing.
command -v companion >/dev/null 2>&1 || { trace hook no-companion-cli "corr=${_t_fp:-}"; exit 0; }

# Pull tool_input.file_path + session_id + cwd out of the payload (Write/Edit carry them).
# cwd feeds companion-index's LATE REGISTRATION only (a session with no registry record);
# a registered session's identity comes from its frozen record, never from cwd.
fp=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log((JSON.parse(d).tool_input||{}).file_path||"")}catch(e){}})' 2>/dev/null)
SID=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})' 2>/dev/null)
CWD=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).cwd||"")}catch(e){}})' 2>/dev/null)

# Push-pop disabled: artifacts no longer spawn their own OS window. The Board is
# the single surface — it ingests artifacts as tiles inside their session via the
# live poll. We DO stamp the routing index here so the Board groups the artifact
# under the WRITING session's unit (keyed on session_id; unit_key resolved from
# that session's live file — cwd is volatile, so never derive from it).
case "$fp" in
  "$ARTIFACTS_DIR"/home.html|"$ARTIFACTS_DIR"/home.*.html)
    # Agent-authored Hub/unit-home surfaces — hosted by the Board, never indexed
    # as one-off artifacts. This arm sits ABOVE the *.html arm (case matches top-down).
    trace hook skip-index "corr=$fp" "reason=unit-home"
    ;;
  "$ARTIFACTS_DIR"/_*.html)
    trace hook skip-index "corr=$fp" "reason=diagnostic-scaffold"
    ;;
  "$ARTIFACTS_DIR"/*.html)
    trace hook index-spawn "corr=$fp"
    SID="$SID" CWD="$CWD" node "$SCRIPT_DIR/companion-index.cjs" "$fp" "$LIVE_DIR" "$INDEX_PATH" 2>/dev/null
    trace hook index-done "corr=$fp"
    ;;
esac

exit 0
