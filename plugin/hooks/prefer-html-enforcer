#!/usr/bin/env sh
# prefer-html-enforcer — Stop hook that nudges Claude to render an HTML artifact
# at end-of-turn when the message looks like a deliverable but no artifact was
# written this turn.
#
# Rationale: the prefer-html skill says "almost always emit some artifact when
# real work was done," but a skill is a recommendation, not an enforcement. This
# Stop hook is the enforcement — it inspects the last assistant message, and
# if it looks like a deliverable (numbered steps, install commands, multiple
# URLs, code blocks, "next steps" phrasing), AND no fresh .html landed in the
# artifacts dir this turn, it returns decision:"block" with a reason that tells
# Claude to render before truly ending.
#
# Loop safety:
#   - The "fresh artifact in the last 2 minutes" check means once Claude renders,
#     the NEXT Stop call passes through cleanly and the turn ends.
#   - Claude Code overrides Stop blocks after 8 consecutive attempts, so a stuck
#     loop self-terminates.
#   - Heuristic is conservative — multiple weak signals required, not one strong
#     one — to avoid nagging on casual replies.
#
# Bypass: any reply that already has a `.html` file in the artifacts dir with
# mtime < 2 min ago is considered "served."
#
# Read-only side effects (writes only stdout JSON, never the filesystem).

ARTIFACTS_DIR="${COMPANION_ARTIFACTS_DIR:-$HOME/codeviz/public/artifacts}"

# Opt-in: hook is a no-op unless the user has run `/companion:enforce on`,
# which creates this flag file. Off by default — skill-guided judgment plus
# the `/companion:render` user-pull verb cover the common case.
ENFORCE_FLAG="${HOME}/.claude/companion/enforce.flag"
[ -f "$ENFORCE_FLAG" ] || exit 0

payload=$(cat)

# Extract last_assistant_message using node if available. Falls back to a tiny
# shell-only check if node isn't present (rare on dev Macs).
msg=""
if command -v node >/dev/null 2>&1; then
  msg=$(printf '%s' "$payload" | node -e '
    let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{
      try{ const j=JSON.parse(d); process.stdout.write(j.last_assistant_message||""); }catch(e){}
    });
  ' 2>/dev/null)
fi

# If we can't extract the message, pass through quietly. Better to under-nag
# than to crash a Stop turn.
if [ -z "$msg" ]; then
  exit 0
fi

# Heuristic score — at least 2 signals = treat as a deliverable.
# Signals are intentionally pattern-cheap (no regex engines) so this runs fast.
score=0

# 1) Numbered-step list (the "next steps" giveaway).
case "$msg" in
  *"1."*"2."*"3."*) score=$((score+1));;
esac

# 2) Install commands the user must copy.
case "$msg" in
  *"install"*|*"Install"*|*"brew "*|*"/plugin install"*|*"npm install"*|*"cargo install"*)
    score=$((score+1));;
esac

# 3) Explicit "next steps" phrasing.
case "$msg" in
  *"Next steps"*|*"next steps"*|*"Next:"*|*"Suggested"*) score=$((score+1));;
esac

# 4) Multiple code blocks (triple-backtick fences ≥ 4 = at least 2 blocks).
case "$msg" in
  *'```'*'```'*'```'*'```'*) score=$((score+1));;
esac

# 5) Multiple URLs.
case "$msg" in
  *http*http*) score=$((score+1));;
esac

# 6) Headed sections — "**…**" bold heads or markdown headings (## / ###).
case "$msg" in
  *"**"*"**"*"**"*"**"*) score=$((score+1));;
esac
case "$msg" in
  *"## "*"## "*) score=$((score+1));;
esac

# 7) Multiple file paths (heuristic: two or more "/Users/" or "~/" absolute paths).
case "$msg" in
  *"/Users/"*"/Users/"*) score=$((score+1));;
esac

# Below threshold = casual reply, pass through.
if [ "$score" -lt 2 ]; then
  exit 0
fi

# Already rendered this turn? mtime < 2 min ago = treat as "served."
if [ -d "$ARTIFACTS_DIR" ]; then
  recent=$(find "$ARTIFACTS_DIR" -maxdepth 1 -name '*.html' -mmin -2 2>/dev/null | head -1)
  if [ -n "$recent" ]; then
    exit 0
  fi
fi

# Block with a focused nudge. The reason field is injected into Claude's next
# turn, so it should read as guidance, not scolding.
cat <<NUDGE
{"decision":"block","reason":"This reply looks like a deliverable (multi-step content, install commands, or next steps) but no HTML artifact was written to ${ARTIFACTS_DIR}/ this turn. Render one now — a self-contained .html file summarising what shipped + the next steps the user should take — then end. See ~/claude-code-companion/plugin/skills/prefer-html/SKILL.md for the template and the required fit-root snippet. The Companion overlay will auto-pop it; the user sees the artifact instead of scrolling a wall of text in five terminals."}
NUDGE

exit 0
