#!/usr/bin/env sh
# companion-consider — Claude Code Stop hook (always-on backstop).
#
# Under the always-on model the live surface (~/.claude/companion/live.json) is
# meant to be refreshed every work turn as part of the normal response — no extra
# round-trip. This hook is just the BACKSTOP: it fires only when a work turn did
# NOT refresh the surface, and nudges Claude to do it. The common path (I updated
# live.json this turn) costs nothing — it exits silently.
#
# Guards:
#   1. stop_hook_active → already nudged this turn; exit (prevents a loop).
#   2. mode == manual   → user opted out; exit.
#   3. current-turn scan → classify THIS turn from the transcript:
#        idle  (no tool use)            → exit (pure chat; nothing to reflect)
#        fresh (wrote live.json)        → exit (surface already refreshed)
#        stale (worked, didn't update)  → nudge
#      Scoped to the current turn (since the last human message), so a previous
#      turn's tool use can't trigger a false nudge.

MODE_FILE="${HOME}/.claude/companion/mode"

payload=$(cat)

# Guard 1 — loop.
case "$payload" in
  *'"stop_hook_active":true'*|*'"stop_hook_active": true'*) exit 0 ;;
esac

# Guard 2 — manual mode (absent file defaults to agent).
if [ "$(cat "$MODE_FILE" 2>/dev/null)" = "manual" ]; then
  exit 0
fi

# Guard 3 — classify the current turn from the transcript. Walk backward to the
# human message that started this turn; collect assistant tool_use along the way.
transcript=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).transcript_path||"")}catch(e){}})')
state="idle"
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
  state=$(node -e '
    const fs=require("fs");
    let lines;
    try { lines = fs.readFileSync(process.argv[1],"utf8").trim().split("\n"); }
    catch (e) { console.log("idle"); process.exit(0); }
    let worked=false, wroteLive=false;
    for (let i=lines.length-1;i>=0;i--){
      let o; try{o=JSON.parse(lines[i]);}catch(e){continue;}
      const msg=o.message||o;
      const role=msg.role||o.type;
      const content=msg.content;
      if (role==="assistant" && Array.isArray(content)){
        for (const b of content){
          if (b && b.type==="tool_use"){
            worked=true;
            const fp=(b.input&&(b.input.file_path||b.input.path))||"";
            if (/companion\/live\.json$/.test(fp)) wroteLive=true;
          }
        }
      }
      if (role==="user"){
        const isTR=Array.isArray(content)&&content.some(b=>b&&b.type==="tool_result");
        if (!isTR) break; // reached the human message that opened this turn
      }
    }
    console.log(worked ? (wroteLive ? "fresh" : "stale") : "idle");
  ' "$transcript" 2>/dev/null)
fi

[ "$state" = "stale" ] || exit 0

# Worked this turn but the live surface is stale — nudge to refresh it.
cat <<'EOF'
{"decision":"block","reason":"Companion: you did real work this turn but didn't refresh the live surface. If the current state changed — what you're working on, where things stand, or the next decisions — rewrite ~/.claude/companion/live.json as {\"working\": \"…\", \"where\": [\"…\"], \"next\": [{\"title\": \"…\", \"sub\": \"…\", \"kind\": \"decision|todo|blocked\"}]} so the always-on pane reflects it. If nothing meaningful changed, just end the turn. Don't narrate that you considered this. (Backstop only — it fires when a work turn skipped the live update.)"}
EOF
exit 0
