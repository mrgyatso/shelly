#!/usr/bin/env sh
# companion-consider — Claude Code Stop hook (always-on backstop).
#
# Goal: when a turn does REAL work or REAL discussion, the user should walk away
# with a beautifully written HTML artifact to digest — not a wall of terminal
# prose. The agent is told (CLAUDE.md / prefer-html) to render artifacts on
# substantive turns, but it forgets / under-judges. This hook is the BACKSTOP:
# it fires ONLY when a substantive turn produced no artifact, and nudges the
# agent to write one. The common paths cost nothing:
#   - the agent already wrote an artifact this turn → exit silently
#   - the turn was trivial (quick lookup, one-liner, ack) → exit silently
#
# It NEVER shells out to a headless `claude` (that is the claude-mem 180s-hang
# pattern) — it is a pure, fast transcript scan. The agent itself, in-context,
# writes the artifact when nudged: most reliable, highest quality (full context,
# already knows prefer-html). A Sonnet-subagent writer is a possible future
# optimization (keeps the big HTML out of the main context) but is not worth the
# lossy handoff for v1.
#
# Guards:
#   1. stop_hook_active → already nudged this turn; exit (prevents a loop).
#   2. mode == manual   → user opted out; exit.
#   3. current-turn scan → classify THIS turn from the transcript:
#        fresh (wrote an artifact)        → exit (already have one)
#        nudge (worked OR long discussion) → block + ask for an artifact
#        idle  (trivial)                  → exit
#      Scoped to the current turn (since the last human message), so a previous
#      turn's tool use can't trigger a false nudge.

MODE_FILE="${HOME}/.claude/companion/mode"
ART_DIR="${COMPANION_ARTIFACTS_DIR:-${HOME}/.claude/companion/artifacts}"

payload=$(cat)

# Guard 1 — loop.
case "$payload" in
  *'"stop_hook_active":true'*|*'"stop_hook_active": true'*) exit 0 ;;
esac

# Guard 2 — manual mode (absent file defaults to agent).
if [ "$(cat "$MODE_FILE" 2>/dev/null)" = "manual" ]; then
  exit 0
fi

# Pull transcript_path out of the payload.
transcript=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).transcript_path||"")}catch(e){}})')

[ -n "$transcript" ] && [ -f "$transcript" ] || exit 0

# Guard 3 — classify the current turn. Walk backward to the human message that
# opened this turn; collect assistant tool_use + final text along the way.
# substantive = (any tool use) OR (assistant text this turn exceeds the
# discussion threshold). "fresh" = a Write/Edit landed an .html under the
# artifacts dir this turn.
state=$(ART_DIR="$ART_DIR" node -e '
  const fs=require("fs");
  const artDir=process.env.ART_DIR;
  const DISCUSSION_CHARS=700; // lean toward driving: even a short substantive answer earns a forward-driving surface
  let lines;
  try { lines = fs.readFileSync(process.argv[1],"utf8").trim().split("\n"); }
  catch (e) { console.log("idle"); process.exit(0); }
  let worked=false, wroteArtifact=false, textLen=0;
  for (let i=lines.length-1;i>=0;i--){
    let o; try{o=JSON.parse(lines[i]);}catch(e){continue;}
    const msg=o.message||o;
    const role=msg.role||o.type;
    const content=msg.content;
    if (role==="assistant" && Array.isArray(content)){
      for (const b of content){
        if (b && b.type==="tool_use"){
          worked=true;
          const fp=(b.input&&(b.input.file_path||b.input.path))||"";
          if (fp.indexOf(artDir)===0 && /\.html?$/.test(fp)) wroteArtifact=true;
        }
        if (b && b.type==="text" && typeof b.text==="string") textLen+=b.text.length;
      }
    }
    if (role==="user"){
      const isTR=Array.isArray(content)&&content.some(b=>b&&b.type==="tool_result");
      if (!isTR) break; // reached the human message that opened this turn
    }
  }
  const substantive = worked || textLen > DISCUSSION_CHARS;
  console.log(wroteArtifact ? "fresh" : (substantive ? "nudge" : "idle"));
' "$transcript" 2>/dev/null)

[ "$state" = "nudge" ] || exit 0

# Substantive turn, no artifact — nudge for one. Emit the decision JSON via node
# so the dynamic dir is escaped correctly.
ART_DIR="$ART_DIR" node -e '
  const dir=process.env.ART_DIR;
  const reason=`Companion — DRIVE THE WORK FORWARD, do not just recap. This turn did real work or real discussion, so render an HTML artifact NOW: load the companion:prefer-html skill, then write a self-contained .html into ${dir}/<slug>.html (the Board ingests it automatically). On a substantive turn this is not optional, and it must NEVER be a thin info block. The artifact has one job: MOVE THE PROJECT toward the goal — solve the problem, build the feature, ship the product. So every artifact must (1) show the information as real UI (state, what changed, the analysis, the options) AND (2) PUSH to the next step — propose concrete next moves, surface the decisions to make, recommend the strongest option and say why, and ask the sharp questions that advance the work. Use the combined informative + Next-steps shape with an interactive decision surface (checkboxes — do-it / note / skip — plus one Submit) so the user acts in one click, not a paragraph of prose. NEVER wait for the user to say what is next; always propose it and offer ideas. If the goal or north-star is unclear, ASK for it INSIDE the artifact (a question surface) so the target gets locked and we keep moving. This supersedes the older "a pill is fine" guidance — a substantive turn earns a forward-driving surface, not a one-liner. Only a genuinely trivial turn (a bare acknowledgement) is exempt. Do not narrate that you considered this.`;
  process.stdout.write(JSON.stringify({decision:"block",reason}));
'
exit 0
