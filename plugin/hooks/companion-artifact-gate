#!/usr/bin/env sh
# companion-artifact-gate — Stop-hook seatbelt for inline artifact authoring.
#
# Artifacts are authored INLINE by the agent now (no background observer, no renderer).
# This seatbelt hands control back ONCE when a turn ends with no .html artifact written,
# so the agent can author it in full, warm-cache context. All logic — turn boundary,
# index check, block/pass — is in companion-artifact-gate.cjs; this wrapper only applies
# the external-terminals guard (same as companion-observe) and passes the hook payload
# (stdin) straight through to node.

# External-terminal handling (default OFF) — only sessions the Board spawned carry
# COMPANION_SESSION; a plain terminal that merely has the plugin installed gets no
# seatbelt (no forced continuation). Opt in per-machine via
# ~/.claude/companion/external-terminals = "on".
if [ -z "$COMPANION_SESSION" ] && [ "$(cat "${HOME}/.claude/companion/external-terminals" 2>/dev/null)" != "on" ]; then
  exit 0
fi

node "$(dirname "$0")/companion-artifact-gate.cjs"
exit 0
