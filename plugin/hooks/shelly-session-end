#!/usr/bin/env sh
# shelly-session-end — Claude Code SessionEnd hook (best-effort).
#
# Drops this instance's live file ONLY when the user genuinely ended the session,
# so a finished agent leaves the Board roster immediately instead of waiting out the
# mtime-staleness window. SessionEnd is NOT guaranteed to fire (crashes, kill -9),
# so this is only an optimization — mtime staleness + the SessionStart prune are
# the real backstops. Never blocks.
#
# CRITICAL: we gate deletion on the SessionEnd `reason`. A FORCED exit — the overlay
# SIGHUPing its embedded claude PTYs when it shuts down for a rebuild/restart, a crash,
# any signal — reports reason "other" (or none). Deleting then made every embedded
# session vanish from the rail on every overlay restart (the reported "sessions keep
# disappearing" bug). For those we KEEP the live file + sidecars so the session survives
# the restart and reappears when the overlay relaunches; mtime-staleness is the backstop.
# Only genuine, user-initiated ends (clear / logout / prompt_input_exit) remove it.

payload=$(cat)

cwd=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).cwd||process.cwd())}catch(e){console.log(process.cwd())}})')
session_id=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})')
reason=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).reason||"")}catch(e){}})')

# Trace harness (no-op unless enabled).
CMP_HOOK_DIR=$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)
. "$CMP_HOOK_DIR/shelly-trace.sh"

# Forced/unknown exit (overlay shutdown SIGHUP, crash, signal) ⇒ keep everything and
# let mtime-staleness reap it. Only a genuine user-initiated end removes the live file.
case "$reason" in
  clear|logout|prompt_input_exit) : ;;  # fall through to cleanup below
  *) trace session end-keep "reason=$reason"; exit 0 ;;
esac

line=$(sh "$(dirname "$0")/shelly-livepath.sh" "$cwd" "$session_id")
live_path=$(printf '%s' "$line" | cut -f1)

trace session end-delete "reason=$reason" "live=$live_path"
rm -f "$live_path" 2>/dev/null

# Also drop this session's stem from the Board-owned sidecars so they don't
# accumulate stale entries across launched sessions (best-effort).
stem=$(basename "$live_path" .json)
STEM="$stem" node -e '
  const fs=require("fs");
  // Object sidecars keyed by stem (stem -> value): drop this stem.
  for (const f of ["owned-sessions.json","session-dirs.json","session-ids.json"]) {
    const p=`${process.env.HOME}/.shelly/${f}`;
    try {
      const m=JSON.parse(fs.readFileSync(p,"utf8"));
      if (m && Object.prototype.hasOwnProperty.call(m, process.env.STEM)) {
        delete m[process.env.STEM];
        const t=p+".tmp"; fs.writeFileSync(t, JSON.stringify(m)); fs.renameSync(t, p);
      }
    } catch (e) {}
  }
  // dismissed.json is an ARRAY of stems — filter this one out so it does not
  // linger after the session is gone.
  const dp=`${process.env.HOME}/.shelly/dismissed.json`;
  try {
    const a=JSON.parse(fs.readFileSync(dp,"utf8"));
    if (Array.isArray(a) && a.includes(process.env.STEM)) {
      const t=dp+".tmp"; fs.writeFileSync(t, JSON.stringify(a.filter(x=>x!==process.env.STEM))); fs.renameSync(t, dp);
    }
  } catch (e) {}
' 2>/dev/null
exit 0
