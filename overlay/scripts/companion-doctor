#!/usr/bin/env sh
# companion-doctor — health check for the Companion overlay setup.
#
# Runs eight checks, prints a plaintext summary to stdout, then renders the same
# report as an HTML panel inside the overlay. Seeing the panel is itself the
# proof that the render path works; the plaintext is the fallback for when the
# overlay is the thing that's broken.
#
# Invoked as `companion doctor` (the wrapper execs here). No args.

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ARTIFACTS_DIR="${COMPANION_ARTIFACTS_DIR:-$HOME/.claude/companion/artifacts}"
OS=$(uname -s)

# Locate the installed app (needed for version + signing checks).
# macOS: the .app bundle. Linux: the .deb's /usr/bin binary.
APP=""
LINUX_BIN=""
if [ "$OS" = Darwin ]; then
  for a in "/Applications/Companion Overlay.app" "$HOME/Applications/Companion Overlay.app"; do
    [ -d "$a" ] && { APP="$a"; break; }
  done
else
  for b in /usr/bin/companion-overlay /usr/local/bin/companion-overlay; do
    [ -x "$b" ] && { LINUX_BIN="$b"; break; }
  done
fi

# --- row accumulation: build HTML and plaintext in parallel ----------------
HTML_ROWS=""
TEXT_ROWS=""
OVERALL=ok

escalate() {
  case "$1" in
    bad) OVERALL=bad ;;
    warn) [ "$OVERALL" = bad ] || OVERALL=warn ;;
  esac
}

add() {  # $1=state(ok|warn|bad)  $2=label  $3=detail
  escalate "$1"
  case "$1" in
    ok)   g="✓"; cls="g"; tg="ok  " ;;
    warn) g="~"; cls="y"; tg="~~  " ;;
    bad)  g="✗"; cls="r"; tg="!!  " ;;
  esac
  HTML_ROWS="${HTML_ROWS}<div class=\"row\"><span class=\"gl ${cls}\">${g}</span><span class=\"lbl\">${2}</span><span class=\"det\">${3}</span></div>"
  TEXT_ROWS="${TEXT_ROWS}  ${tg}${2}  —  ${3}
"
}

# 1. app installed --------------------------------------------------------
if [ -n "$APP" ]; then
  ver=$(/usr/bin/defaults read "$APP/Contents/Info" CFBundleShortVersionString 2>/dev/null || echo "?")
  add ok "app installed" "$APP ($ver)"
elif [ -n "$LINUX_BIN" ]; then
  ver=$(dpkg-query -W -f='${Version}' companion-overlay 2>/dev/null || echo "?")
  add ok "app installed" "$LINUX_BIN ($ver)"
elif [ -x "$SCRIPT_DIR/../src-tauri/target/release/companion-overlay" ] \
  || [ -x "$SCRIPT_DIR/../src-tauri/target/debug/companion-overlay" ]; then
  add warn "app installed" "not installed system-wide — using a local dev build"
elif [ "$OS" = Darwin ]; then
  add bad "app installed" "Companion Overlay.app not found — install the DMG"
else
  add bad "app installed" "companion-overlay not found — install the .deb"
fi

# 2. cli on PATH ----------------------------------------------------------
cli=$(command -v companion 2>/dev/null || true)
if [ -n "$cli" ]; then
  add ok "cli on PATH" "$cli"
else
  add warn "cli on PATH" "not linked — ln -s '$SCRIPT_DIR/companion' /usr/local/bin/companion"
fi

# 2b. node ----------------------------------------------------------------
# Every plugin hook shells out to node. Claude Code ships as a native binary,
# so node is not implied by having `claude` installed.
if command -v node >/dev/null 2>&1; then
  add ok "node" "$(node -v)"
else
  case "$OS" in
    Darwin) node_hint="brew install node" ;;
    *) node_hint="sudo apt install nodejs" ;;
  esac
  add bad "node" "absent — the plugin's hooks are Node scripts ($node_hint)"
fi

# 3. overlay daemon -------------------------------------------------------
# Linux truncates `comm` to 15 chars, so the process reads as "companion-overl" and
# `pgrep -x companion-overlay` never matches it — the daemon always reported idle,
# even with the app on screen. Anchor on the short form, which is also what macOS's
# untruncated name starts with. Matching `comm` rather than the full cmdline keeps
# this from ever selecting the doctor itself.
pids=$(ps -eo pid=,comm= 2>/dev/null \
  | awk '$2 ~ /^companion-overl/ { printf "%s ", $1 }' \
  | sed 's/ *$//')
if [ -n "$pids" ]; then
  add ok "overlay daemon" "running (pid $pids)"
else
  add warn "overlay daemon" "idle — starts on the first 'companion open'"
fi

# 4. hooks wired ----------------------------------------------------------
# Two supported paths: the plugin (which carries its own hooks.json — nothing
# lands in settings.json), or a hand-added hook in settings.json. Check the
# plugin FIRST; grepping settings.json alone reports a false failure on the
# recommended install.
if claude plugin list 2>/dev/null | grep -q "companion@claude-code-companion"; then
  add ok "hooks wired" "via the companion plugin"
else
  hook_found=""
  for s in "$HOME/.claude/settings.json" "$HOME/.claude/settings.local.json"; do
    if [ -f "$s" ] && grep -q "companion-hook" "$s" 2>/dev/null; then
      hook_found="${s#"$HOME"/}"
      break
    fi
  done
  if [ -n "$hook_found" ]; then
    add ok "hooks wired" "by hand, in $hook_found"
  else
    add bad "hooks wired" "absent — run 'companion setup'"
  fi
fi

# 4b. session handling ----------------------------------------------------
# The plugin ignores terminals the app did not spawn unless opted in. Without
# this row, "installed everything, my terminal does nothing" has no diagnosis.
if [ "$(cat "$HOME/.claude/companion/external-terminals" 2>/dev/null)" = on ]; then
  add ok "session handling" "all terminals, including ones started outside the app"
else
  add warn "session handling" "app-spawned sessions only — 'companion setup --external-terminals' for the rest"
fi

# 5. artifacts dir --------------------------------------------------------
if [ -d "$ARTIFACTS_DIR" ]; then
  add ok "artifacts dir" "$ARTIFACTS_DIR"
else
  add warn "artifacts dir" "$ARTIFACTS_DIR (missing — set COMPANION_ARTIFACTS_DIR or create it)"
fi

# 6. signed / notarized (macOS only — Linux has no Gatekeeper) -------------
if [ "$OS" = Darwin ]; then
  if [ -n "$APP" ]; then
    if spctl -a -t exec "$APP" >/dev/null 2>&1; then
      add ok "signed / notarized" "accepted by Gatekeeper"
    else
      add warn "signed / notarized" "unsigned preview — right-click → Open the first time"
    fi
  else
    add warn "signed / notarized" "n/a — app not installed"
  fi
fi

# --- headline ------------------------------------------------------------
case "$OVERALL" in
  ok)   HEAD="All systems go";       HCLS="g" ;;
  warn) HEAD="Working, with notes";  HCLS="y" ;;
  bad)  HEAD="Action needed";        HCLS="r" ;;
esac
TS=$(date '+%Y-%m-%d %H:%M')

# --- plaintext (always, even if the overlay can't render) ----------------
printf '\ncompanion doctor — %s\n' "$HEAD"
printf '%s\n' "$TEXT_ROWS"

# --- HTML panel, rendered in the overlay ---------------------------------
OUT="${TMPDIR:-/tmp}/companion-doctor.html"
cat > "$OUT" <<HTML
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>companion doctor</title>
<style>
  :root {
    --paper:#f4f1ec; --surface:#ffffff; --ink:#1a1714; --muted:#6e655b;
    --accent:#ff6a5a; --accent-ink:#c4392b; --ok:#2e7d52; --warn:#b07d23; --bad:#c4392b;
    --line:rgba(26,23,20,0.12);
    --mono:ui-monospace,"SF Mono","JetBrains Mono",Menlo,monospace;
    --serif:"Iowan Old Style","Palatino Linotype",Palatino,Georgia,serif;
    --sans:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  }
  *{box-sizing:border-box;}
  html{scrollbar-width:none;}
  html::-webkit-scrollbar{width:0;height:0;display:none;}
  html,body{margin:0;background:var(--paper);color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased;}
  [data-fit-root]{width:600px;margin:0 auto;padding:26px 28px 22px;}
  .top{display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:4px;}
  .eyebrow{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent-ink);}
  .ts{font-family:var(--mono);font-size:11px;color:var(--muted);}
  h1{font-family:var(--serif);font-size:26px;font-weight:600;letter-spacing:-0.01em;margin:6px 0 18px;}
  h1 .pin{display:inline-block;width:10px;height:10px;border-radius:999px;margin-right:9px;vertical-align:middle;}
  h1 .pin.g{background:var(--ok);} h1 .pin.y{background:var(--warn);} h1 .pin.r{background:var(--bad);}
  .rows{display:grid;gap:2px;background:var(--surface);border:1px solid var(--line);border-radius:13px;padding:8px;}
  .row{display:grid;grid-template-columns:22px 152px 1fr;gap:10px;align-items:baseline;padding:9px 10px;border-radius:9px;}
  .row:nth-child(odd){background:rgba(26,23,20,0.025);}
  .gl{font-family:var(--mono);font-weight:700;font-size:14px;text-align:center;}
  .gl.g{color:var(--ok);} .gl.y{color:var(--warn);} .gl.r{color:var(--bad);}
  .lbl{font-size:14px;font-weight:600;}
  .det{font-family:var(--mono);font-size:11.5px;color:var(--muted);line-height:1.45;word-break:break-word;}
  .foot{margin-top:14px;font-size:12px;color:var(--muted);text-align:center;}
  .foot b{color:var(--accent-ink);}
</style>
</head>
<body>
<main data-fit-root>
  <div class="top"><span class="eyebrow">companion · doctor</span><span class="ts">$TS</span></div>
  <h1><span class="pin $HCLS"></span>$HEAD</h1>
  <div class="rows">$HTML_ROWS</div>
  <div class="foot">You are reading this <b>inside the overlay</b> — so the render path works.</div>
</main>
<script>
  (function(){
    var el=document.querySelector("[data-fit-root]")||document.body;
    var post=function(){parent.postMessage({source:"companion-artifact",kind:"size",
      w:Math.ceil(el.scrollWidth),h:Math.ceil(el.scrollHeight)},"*");};
    if(typeof ResizeObserver!=="undefined") new ResizeObserver(post).observe(el);
    addEventListener("load",post); post();
  })();
</script>
</body>
</html>
HTML

# Render it (ignore failure — plaintext above already gave the diagnosis).
#
# Only when someone is actually watching. With no TTY on stdout we're in CI, a
# pipe, or a hook: popping a GUI there strands a daemon nobody asked for and
# nobody will quit. The plaintext diagnosis above is the whole answer in that case.
if [ -t 1 ]; then
  "$SCRIPT_DIR/companion" open "$OUT" >/dev/null 2>&1 || true
fi
