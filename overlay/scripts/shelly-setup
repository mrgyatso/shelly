#!/usr/bin/env sh
# shelly-setup — wire the Claude Code plugin to this app, then verify.
#
# The second (and last) command of a fresh install:
#
#   brew install --cask mrgyatso/tap/shelly
#   shelly setup
#
# Adds the marketplace, installs the plugin, creates the watched dirs, and hands
# off to `shelly doctor`. Safe to re-run: every step is skipped if already done.
#
# Invoked as `shelly setup` (the wrapper execs here).
#
# Flags:
#   --external-terminals   also handle `claude` sessions started outside the app

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
STATE_DIR="$HOME/.shelly"
ARTIFACTS_DIR="${SHELLY_ARTIFACTS_DIR:-$STATE_DIR/artifacts}"
MARKETPLACE=shelly
PLUGIN=shelly@shelly

WANT_EXTERNAL=""
for arg in "$@"; do
  case "$arg" in
    --external-terminals) WANT_EXTERNAL=1 ;;
    *) echo "shelly setup: unknown flag '$arg'" >&2; exit 2 ;;
  esac
done

say()  { printf '  %s\n' "$1"; }
# A refresh that fails is not fatal — the machine is already wired and working, it just
# did not get newer code (no network, most likely). Say so and carry on.
warn() { printf '  %s\n' "$1" >&2; }
fail() { printf '\nshelly setup: %s\n' "$1" >&2; shift; for l in "$@"; do printf '  %s\n' "$l" >&2; done; exit 1; }

printf '\nshelly setup\n\n'

# 0. Migration, from back when this was called Companion. The data home moved from
#    ~/.claude/companion to ~/.shelly — not for the name, but because ~/.claude is
#    Claude Code's directory and we also track Codex sessions.
#
#    Move it once, then leave a symlink behind. The symlink is the load-bearing half:
#    artifacts written before the move hardcode asset://…/.claude/companion/vendor/…
#    URLs into their <head>, and a running overlay is still polling the old path. Both
#    keep resolving through the link. Only migrate when the destination is absent —
#    if both exist, someone has already moved on and merging could clobber real state.
OLD_STATE_DIR="$HOME/.claude/companion"
if [ -d "$OLD_STATE_DIR" ] && [ ! -L "$OLD_STATE_DIR" ] && [ ! -e "$STATE_DIR" ]; then
  if mv "$OLD_STATE_DIR" "$STATE_DIR" 2>/dev/null; then
    ln -s "$STATE_DIR" "$OLD_STATE_DIR" 2>/dev/null
    say "migrated    ~/.claude/companion → ~/.shelly (old path left as a symlink)"
  else
    warn "migrated    could not move ~/.claude/companion → ~/.shelly — move it by hand:"
    warn "            mv ~/.claude/companion ~/.shelly && ln -s ~/.shelly ~/.claude/companion"
  fi
elif [ -d "$OLD_STATE_DIR" ] && [ ! -L "$OLD_STATE_DIR" ] && [ -e "$STATE_DIR" ]; then
  warn "migrated    both ~/.claude/companion and ~/.shelly exist — left alone, merge by hand"
fi

# 1. Node — every plugin hook shells out to it. Claude Code ships as a native
#    binary now, so node is NOT implied by having `claude` on PATH.
command -v node >/dev/null 2>&1 || fail "node not found on PATH." \
  "The plugin's hooks are Node scripts. Install Node 18 or later:" \
  "  brew install node"
say "node        $(node -v)"

# 2. At least one agent CLI — the plugin lives inside whichever you use. Neither
#    installed is the only fatal case; one missing CLI is just skipped (it wires
#    itself when it appears: re-run setup, or the app auto-wires codex on launch).
HAVE_CLAUDE=""
HAVE_CODEX=""
command -v claude >/dev/null 2>&1 && HAVE_CLAUDE=1
command -v codex >/dev/null 2>&1 && HAVE_CODEX=1
[ -n "${HAVE_CLAUDE}${HAVE_CODEX}" ] || fail "no agent CLI found on PATH." \
  "Shelly wires itself into Claude Code and/or Codex — install one first:" \
  "  Claude Code: https://claude.com/claude-code" \
  "  Codex:       npm install -g @openai/codex"
if [ -n "$HAVE_CLAUDE" ]; then
  say "claude      $(command -v claude)"
else
  say "claude      not installed — skipped (wires itself once installed)"
fi

# 3. Marketplace. Never re-`add` when present: a re-add overwrites the source, which
#    would silently repoint a contributor's local checkout at GitHub. `update` pulls
#    from whatever source is already configured, so it is safe for both.
if [ -n "$HAVE_CLAUDE" ]; then
  if claude plugin marketplace list 2>/dev/null | grep -q "❯ ${MARKETPLACE}\$"; then
    if claude plugin marketplace update "${MARKETPLACE}" >/dev/null 2>&1; then
      say "marketplace ${MARKETPLACE} (refreshed)"
    else
      warn "marketplace ${MARKETPLACE} (configured; could not refresh — offline?)"
    fi
  else
    claude plugin marketplace add mrgyatso/shelly >/dev/null 2>&1 \
      || fail "could not add the marketplace." "Run it by hand to see why:" \
              "  claude plugin marketplace add mrgyatso/shelly"
    say "marketplace ${MARKETPLACE} (added)"
  fi
fi

# 4. Plugin. An install that is already present still needs `update` — the plugin is
#    fetched from the marketplace, NOT carried in the app bundle, so a newer app does
#    not imply newer plugin code. Without this, re-running the installer left the old
#    hooks and skills in place forever.
#
#    `claude plugin update <plugin>` updates the USER scope. Shelly is installed per
#    PROJECT, so the bare command fails on every machine that has it —
#
#        ✘ Plugin "shelly" is not installed at scope user
#
#    — and the old code caught that and printed "could not update — offline?". It was
#    never offline. The refresh had simply never worked: `shelly setup` claimed to
#    have run while the plugin sat stale for weeks, which is exactly the silent rot the
#    in-app Update button exists to end. Ask the manifest where the plugin actually
#    lives and update it there.

# One line per install: "user", or "project<TAB></abs/path>".
plugin_scopes() {
  node -e '
    const fs = require("fs"), os = require("os"), path = require("path");
    const f = path.join(os.homedir(), ".claude", "plugins", "installed_plugins.json");
    let j;
    try { j = JSON.parse(fs.readFileSync(f, "utf8")); } catch (e) { process.exit(0); }
    for (const i of (j.plugins || {})["shelly@shelly"] || []) {
      if (i.scope === "user") console.log("user");
      else if (i.projectPath) console.log("project\t" + i.projectPath);
    }
  ' 2>/dev/null
}

if [ -n "$HAVE_CLAUDE" ]; then
  if claude plugin list 2>/dev/null | grep -q "${PLUGIN}"; then
    updated=0
    failed=0
    scopes=$(plugin_scopes)
    if [ -z "$scopes" ]; then
      # `plugin list` sees it but the manifest does not say where. Fall back to the
      # CLI's own default rather than skipping the refresh outright.
      if claude plugin update "${PLUGIN}" >/dev/null 2>&1; then updated=1; else failed=1; fi
    else
      # Fed by here-doc, not a pipe: in POSIX sh a piped `while` runs in a subshell, and
      # the counters set inside it would be discarded at the loop's end.
      while IFS="$(printf '\t')" read -r scope proj; do
        [ -n "$scope" ] || continue
        if [ "$scope" = user ]; then
          if claude plugin update "${PLUGIN}" --scope user >/dev/null 2>&1; then
            updated=$((updated + 1))
          else
            failed=$((failed + 1))
          fi
        elif [ -d "$proj" ]; then
          # --scope project resolves against the CWD, so we have to stand in the project.
          # Subshell'd so the cd cannot leak into the rest of setup.
          if (cd "$proj" && claude plugin update "${PLUGIN}" --scope project >/dev/null 2>&1); then
            updated=$((updated + 1))
          else
            failed=$((failed + 1))
          fi
        fi
        # A projectPath that no longer exists is neither updated nor failed — the repo
        # is gone, so there is nothing left to keep current.
      done <<EOF
$scopes
EOF
    fi

    if [ "$failed" -gt 0 ] && [ "$updated" -eq 0 ]; then
      warn "plugin      ${PLUGIN} (installed; could not update — offline?)"
    elif [ "$failed" -gt 0 ]; then
      say "plugin      ${PLUGIN} (updated in ${updated}; ${failed} could not be reached)"
    elif [ "$updated" -gt 1 ]; then
      say "plugin      ${PLUGIN} (updated in ${updated} projects)"
    else
      say "plugin      ${PLUGIN} (updated)"
    fi
  else
    claude plugin install "${PLUGIN}" >/dev/null 2>&1 \
      || fail "could not install the plugin." "Run it by hand to see why:" \
              "  claude plugin install ${PLUGIN}"
    say "plugin      ${PLUGIN} (installed)"
  fi
fi

# 4b. Codex CLI (optional). Codex's plugin system consumes this same Claude-format
#     marketplace and plugin as-is, and its hooks system runs the same hook scripts —
#     so wiring it is the same two steps under the other CLI. Entirely skipped when
#     codex isn't installed; never fatal (Claude is the primary path).
#     Same never-re-`add` rule as step 3: an add would repoint a contributor's local
#     marketplace source, so a configured one only ever gets `upgrade`d (which is a
#     no-op for local sources).
if command -v codex >/dev/null 2>&1; then
  if codex plugin marketplace list 2>/dev/null | grep -q "^${MARKETPLACE}[[:space:]]"; then
    codex plugin marketplace upgrade "${MARKETPLACE}" >/dev/null 2>&1 \
      && say "codex mkt   ${MARKETPLACE} (refreshed)" \
      || say "codex mkt   ${MARKETPLACE} (configured)"
  else
    if codex plugin marketplace add "https://github.com/mrgyatso/shelly" >/dev/null 2>&1; then
      say "codex mkt   ${MARKETPLACE} (added)"
    else
      warn "codex mkt   could not add the marketplace — wire it by hand:"
      warn "            codex plugin marketplace add https://github.com/mrgyatso/shelly"
    fi
  fi
  if codex plugin list 2>/dev/null | grep -q "^${PLUGIN}[[:space:]]"; then
    say "codex plug  ${PLUGIN} (installed)"
  else
    if codex plugin add "${PLUGIN}" >/dev/null 2>&1; then
      say "codex plug  ${PLUGIN} (installed)"
    else
      warn "codex plug  could not install — run by hand: codex plugin add ${PLUGIN}"
    fi
  fi
  say "codex       one-time step: your first codex session opens with 'Hooks need review' — choose 'Trust all and continue'"
else
  say "codex       not installed — skipped (Codex support wires itself when codex is on PATH)"
fi

# 5. Watched dirs — the overlay polls these; create them so the first artifact
#    write doesn't race a missing directory.
mkdir -p "$ARTIFACTS_DIR" "$STATE_DIR/live"
say "artifacts   $ARTIFACTS_DIR"

# 6. External terminals. Off by default: the plugin only acts in terminals the
#    app itself spawned. Opt in here, or later by writing the flag file.
if [ -n "$WANT_EXTERNAL" ]; then
  echo on > "$STATE_DIR/external-terminals"
  say "external    on — sessions started outside the app are handled too"
elif [ "$(cat "$STATE_DIR/external-terminals" 2>/dev/null)" = on ]; then
  say "external    on"
else
  say "external    off — start sessions from inside the app (or re-run with --external-terminals)"
fi

printf '\nRestart any running `claude` session so it picks up the plugin, then:\n'
printf '\n  shelly board\n\n'

exec "$SCRIPT_DIR/shelly-doctor"
