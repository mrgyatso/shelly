#!/usr/bin/env sh
# companion-setup — wire the Claude Code plugin to this app, then verify.
#
# The second (and last) command of a fresh install:
#
#   brew install --cask mrgyatso/tap/claude-code-companion
#   companion setup
#
# Adds the marketplace, installs the plugin, creates the watched dirs, and hands
# off to `companion doctor`. Safe to re-run: every step is skipped if already done.
#
# Invoked as `companion setup` (the wrapper execs here).
#
# Flags:
#   --external-terminals   also handle `claude` sessions started outside the app

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
STATE_DIR="$HOME/.claude/companion"
ARTIFACTS_DIR="${COMPANION_ARTIFACTS_DIR:-$STATE_DIR/artifacts}"
MARKETPLACE=claude-code-companion
PLUGIN=companion@claude-code-companion

WANT_EXTERNAL=""
for arg in "$@"; do
  case "$arg" in
    --external-terminals) WANT_EXTERNAL=1 ;;
    *) echo "companion setup: unknown flag '$arg'" >&2; exit 2 ;;
  esac
done

say()  { printf '  %s\n' "$1"; }
# A refresh that fails is not fatal — the machine is already wired and working, it just
# did not get newer code (no network, most likely). Say so and carry on.
warn() { printf '  %s\n' "$1" >&2; }
fail() { printf '\ncompanion setup: %s\n' "$1" >&2; shift; for l in "$@"; do printf '  %s\n' "$l" >&2; done; exit 1; }

printf '\ncompanion setup\n\n'

# 1. Node — every plugin hook shells out to it. Claude Code ships as a native
#    binary now, so node is NOT implied by having `claude` on PATH.
command -v node >/dev/null 2>&1 || fail "node not found on PATH." \
  "The plugin's hooks are Node scripts. Install Node 18 or later:" \
  "  brew install node"
say "node        $(node -v)"

# 2. At least one agent CLI — the plugin lives inside whichever you use. Neither
#    installed is the only fatal case; one missing CLI is just skipped (it wires
#    itself when it appears: re-run setup, or the app auto-wires codex on launch).
HAVE_CLAUDE=""
HAVE_CODEX=""
command -v claude >/dev/null 2>&1 && HAVE_CLAUDE=1
command -v codex >/dev/null 2>&1 && HAVE_CODEX=1
[ -n "${HAVE_CLAUDE}${HAVE_CODEX}" ] || fail "no agent CLI found on PATH." \
  "Companion wires itself into Claude Code and/or Codex — install one first:" \
  "  Claude Code: https://claude.com/claude-code" \
  "  Codex:       npm install -g @openai/codex"
if [ -n "$HAVE_CLAUDE" ]; then
  say "claude      $(command -v claude)"
else
  say "claude      not installed — skipped (wires itself once installed)"
fi

# 3. Marketplace. Never re-`add` when present: a re-add overwrites the source, which
#    would silently repoint a contributor's local checkout at GitHub. `update` pulls
#    from whatever source is already configured, so it is safe for both.
if [ -n "$HAVE_CLAUDE" ]; then
  if claude plugin marketplace list 2>/dev/null | grep -q "❯ ${MARKETPLACE}\$"; then
    if claude plugin marketplace update "${MARKETPLACE}" >/dev/null 2>&1; then
      say "marketplace ${MARKETPLACE} (refreshed)"
    else
      warn "marketplace ${MARKETPLACE} (configured; could not refresh — offline?)"
    fi
  else
    claude plugin marketplace add mrgyatso/claude-code-companion >/dev/null 2>&1 \
      || fail "could not add the marketplace." "Run it by hand to see why:" \
              "  claude plugin marketplace add mrgyatso/claude-code-companion"
    say "marketplace ${MARKETPLACE} (added)"
  fi
fi

# 4. Plugin. An install that is already present still needs `update` — the plugin is
#    fetched from the marketplace, NOT carried in the app bundle, so a newer app does
#    not imply newer plugin code. Without this, re-running the installer left the old
#    hooks and skills in place forever.
if [ -n "$HAVE_CLAUDE" ]; then
  if claude plugin list 2>/dev/null | grep -q "${PLUGIN}"; then
    if claude plugin update "${PLUGIN}" >/dev/null 2>&1; then
      say "plugin      ${PLUGIN} (updated)"
    else
      warn "plugin      ${PLUGIN} (installed; could not update — offline?)"
    fi
  else
    claude plugin install "${PLUGIN}" >/dev/null 2>&1 \
      || fail "could not install the plugin." "Run it by hand to see why:" \
              "  claude plugin install ${PLUGIN}"
    say "plugin      ${PLUGIN} (installed)"
  fi
fi

# 4b. Codex CLI (optional). Codex's plugin system consumes this same Claude-format
#     marketplace and plugin as-is, and its hooks system runs the same hook scripts —
#     so wiring it is the same two steps under the other CLI. Entirely skipped when
#     codex isn't installed; never fatal (Claude is the primary path).
#     Same never-re-`add` rule as step 3: an add would repoint a contributor's local
#     marketplace source, so a configured one only ever gets `upgrade`d (which is a
#     no-op for local sources).
if command -v codex >/dev/null 2>&1; then
  if codex plugin marketplace list 2>/dev/null | grep -q "^${MARKETPLACE}[[:space:]]"; then
    codex plugin marketplace upgrade "${MARKETPLACE}" >/dev/null 2>&1 \
      && say "codex mkt   ${MARKETPLACE} (refreshed)" \
      || say "codex mkt   ${MARKETPLACE} (configured)"
  else
    if codex plugin marketplace add "https://github.com/mrgyatso/claude-code-companion" >/dev/null 2>&1; then
      say "codex mkt   ${MARKETPLACE} (added)"
    else
      warn "codex mkt   could not add the marketplace — wire it by hand:"
      warn "            codex plugin marketplace add https://github.com/mrgyatso/claude-code-companion"
    fi
  fi
  if codex plugin list 2>/dev/null | grep -q "^${PLUGIN}[[:space:]]"; then
    say "codex plug  ${PLUGIN} (installed)"
  else
    if codex plugin add "${PLUGIN}" >/dev/null 2>&1; then
      say "codex plug  ${PLUGIN} (installed)"
    else
      warn "codex plug  could not install — run by hand: codex plugin add ${PLUGIN}"
    fi
  fi
  say "codex       one-time step: run /hooks inside codex and trust the companion hooks"
else
  say "codex       not installed — skipped (Codex support wires itself when codex is on PATH)"
fi

# 5. Watched dirs — the overlay polls these; create them so the first artifact
#    write doesn't race a missing directory.
mkdir -p "$ARTIFACTS_DIR" "$STATE_DIR/live"
say "artifacts   $ARTIFACTS_DIR"

# 6. External terminals. Off by default: the plugin only acts in terminals the
#    app itself spawned. Opt in here, or later by writing the flag file.
if [ -n "$WANT_EXTERNAL" ]; then
  echo on > "$STATE_DIR/external-terminals"
  say "external    on — sessions started outside the app are handled too"
elif [ "$(cat "$STATE_DIR/external-terminals" 2>/dev/null)" = on ]; then
  say "external    on"
else
  say "external    off — start sessions from inside the app (or re-run with --external-terminals)"
fi

printf '\nRestart any running `claude` session so it picks up the plugin, then:\n'
printf '\n  companion board\n\n'

exec "$SCRIPT_DIR/companion-doctor"
