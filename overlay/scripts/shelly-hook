#!/usr/bin/env sh
# shelly-hook â€” Claude Code PostToolUse hook.
# Pops the overlay when an HTML artifact is written into the artifacts dir.
# Reads the hook JSON payload on stdin; never blocks the originating write.
#
# The watched dir is $SHELLY_ARTIFACTS_DIR (default: $HOME/codeviz/public/artifacts).
#
# Wire it (global) in ~/.claude/settings.json â€” use the absolute path to this file:
#   "PostToolUse": [{ "matcher": "Write|Edit",
#     "hooks": [{ "type": "command",
#       "command": "</abs/path/to>/overlay/scripts/shelly-hook" }] }]

ARTIFACTS_DIR="${SHELLY_ARTIFACTS_DIR:-$HOME/.shelly/artifacts}"
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
LIVE_DIR="$HOME/.shelly/live"
INDEX_PATH="$HOME/.shelly/artifact-index.json"

# Trace harness (no-op unless SHELLY_TRACE=1 / the trace.on flag file exists).
CMP_HOOK_DIR="$SCRIPT_DIR"
. "$SCRIPT_DIR/shelly-trace.sh"

payload=$(cat)

# Cheap pre-filter: skip the JSON parse for the 99% of writes that aren't artifacts.
case "$payload" in
  *"$ARTIFACTS_DIR"/*) ;;
  *) exit 0 ;;
esac

# Pull tool_input.file_path + session_id out of the payload (Write/Edit both carry them).
fp=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log((JSON.parse(d).tool_input||{}).file_path||"")}catch(e){}})')
SID=$(printf '%s' "$payload" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{try{console.log(JSON.parse(d).session_id||"")}catch(e){}})')

# `copy=overlay-scripts` distinguishes this firing from the plugin-cache copy of the
# hook (PostToolUse is registered twice â€” settings.json AND the plugin), so the trace
# shows the double-registration plainly.
trace hook fire "corr=$fp" "file_path=$fp" "sid=$SID" "artifacts_dir=$ARTIFACTS_DIR" "hookpid=$$" "copy=overlay-scripts"

case "$fp" in
  "$ARTIFACTS_DIR"/*.html)
    # Stamp the routing index so the Board groups this artifact under the WRITING
    # session's unit â€” keyed on session_id (stable), unit_key resolved from that
    # session's live file (cwd is volatile within a session, so never derive from it).
    # Skip reserved/scaffold names (home.html, home.<unit>.html, _diag-*).
    base=$(basename "$fp")
    case "$base" in
      home.html|home.*|_*) trace hook skip-index "corr=$fp" "reason=reserved-name" ;;
      *)
        trace hook index-spawn "corr=$fp"
        SID="$SID" node "$SCRIPT_DIR/shelly-index.cjs" "$fp" "$LIVE_DIR" "$INDEX_PATH" 2>/dev/null
        trace hook index-done "corr=$fp"
        ;;
    esac
    # The Board is the single surface â€” it ingests artifacts via the live poll +
    # native watcher. No standalone window: the obsolete `shelly open` pop was
    # removed here (the cleanup that also dropped the redundant settings.json
    # registration of this hook; PostToolUse now fires once, via the plugin).
    ;;
esac

exit 0
