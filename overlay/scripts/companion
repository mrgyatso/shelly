#!/usr/bin/env sh
# companion — drive the floating HTML artifact overlay.
#
#   companion open <file.html>   load an artifact (launches the overlay if needed)
#
# Invoking the real binary (not `open -a`) is what lets tauri-plugin-single-instance
# forward these args to an already-running overlay. Resolves the binary from the
# installed .app first, then the local dev/release build.
set -e

# Resolve $0 through symlinks (e.g. /usr/local/bin/companion) so SCRIPT_DIR is
# the real scripts dir — needed to find sibling scripts like companion-doctor.
SELF=$0
while [ -L "$SELF" ]; do
  target=$(readlink "$SELF")
  case "$target" in
    /*) SELF=$target ;;
    *) SELF=$(dirname "$SELF")/$target ;;
  esac
done
SCRIPT_DIR=$(cd "$(dirname "$SELF")" && pwd)

# Subcommands handled in the wrapper. Everything else is passed to the binary,
# which routes on argv itself (see launch.rs): no args or `board` opens the
# Board, plus `open <file>`, `history` and `live`.
case "$1" in
  doctor) exec "$SCRIPT_DIR/companion-doctor" ;;
  setup) shift; exec "$SCRIPT_DIR/companion-setup" "$@" ;;
  hub) shift; exec "$SCRIPT_DIR/companion-hub" "$@" ;;
  uninstall) shift; exec "$SCRIPT_DIR/companion-uninstall" "$@" ;;
esac

# macOS: the installed .app. Linux: the .deb's /usr/bin binary. Both lists are
# probed everywhere — a path that doesn't exist is just skipped.
CANDIDATES="/Applications/Companion Overlay.app/Contents/MacOS/companion-overlay
$HOME/Applications/Companion Overlay.app/Contents/MacOS/companion-overlay
/usr/bin/companion-overlay
/usr/local/bin/companion-overlay
$SCRIPT_DIR/../src-tauri/target/release/companion-overlay
$SCRIPT_DIR/../src-tauri/target/debug/companion-overlay"

BIN=""
IFS='
'
for c in $CANDIDATES; do
  [ -n "$c" ] || continue
  if [ -x "$c" ]; then BIN="$c"; break; fi
done
unset IFS

if [ -z "$BIN" ]; then
  echo "companion: overlay binary not found." >&2
  echo "  Build it: cd overlay && npm run tauri build   (or run 'npm run tauri dev')" >&2
  exit 1
fi

# Detach, never exec. Every surface the binary routes to (board, open, history,
# live — see launch.rs) is a GUI window; none of them write to stdout, so holding
# the terminal buys nothing and costs everything:
#
#   daemon already up  → this process forwards its argv over the single-instance
#                        socket and exits immediately. Detaching changes nothing.
#   daemon not up      → this process *becomes* the daemon. Under `exec` it never
#                        returns, so the caller hangs until the app quits. That is
#                        what wedged `companion doctor` on every fresh install, and
#                        blocked forever in CI where nothing ever quits it.
#
# Backgrounding costs us the binary's exit status, which we never surfaced anyway.
nohup "$BIN" "$@" >/dev/null 2>&1 &
