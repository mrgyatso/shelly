{
  "name": "companion-overlay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "harness": "vite --port 1430 --open /dev/board-harness.html",
    "build": "tsc && vite build",
    "demo": "node scripts/gen-demo-html.mjs && vite --config vite.demo.config.ts",
    "build:demo": "node scripts/gen-demo-html.mjs && vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "node --experimental-strip-types scripts/check-ingest-rewrite.ts && node --experimental-strip-types scripts/check-sibling-unread.ts && node --experimental-strip-types scripts/check-compact-state.ts && node --experimental-strip-types scripts/check-unit-identity.ts && node --experimental-strip-types scripts/check-demo-loop.ts && node ../plugin/hooks/__tests__/run.cjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-deep-link": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.55.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
